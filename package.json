{
    "name": "@farmerbit/vite-plugin",
    "version": "1.0.0",
    "type": "module",
    "license": "MIT",
    "description": "A Vite plugin for working with WordPress.",
    "keywords": [
        "wordpress",
        "vite",
        "vite-plugin"
    ],
    "contributors": [
        {
            "email": "developer6@farmerbit.com",
            "name": "Mahmoud",
            "url": "https://github.com/mahmoud-alawad"
        }
    ],
    "exports": {
        ".": {
            "types": "./dist/src/index.d.ts",
            "default": "./dist/index.js"
        }
    },
    "types": "./dist/src/index.d.ts",
    "files": [
        "/dist"
    ],
    "engines": {
        "node": "^20.19.0 || >=22.12.0"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/Farmerbit/flynt-vite-plugin.git"
    },
    "homepage": "https://github.com/Farmerbit/flynt-vite-plugin",
    "scripts": {
        "build": "rm -rf dist && tsc --emitDeclarationOnly && esbuild src/index.ts --bundle --platform=node --format=esm --outfile=dist/index.js --packages=external",
        "lint": "eslint ./src ./tests",
        "lint:fix": "eslint --fix ./src ./tests",
        "test": "vitest run"
    },
    "dependencies": {
        "@wordpress/dependency-extraction-webpack-plugin": "^6.40.0"
    },
    "peerDependencies": {
        "vite": "^8.0.0"
    },
    "devDependencies": {
        "@eslint/eslintrc": "^3.3.1",
        "@eslint/js": "^9.32.0",
        "@tailwindcss/oxide": "^4.1.11",
        "@tailwindcss/vite": "^4.1.11",
        "@types/node": "^20.19.0 || >=22.12.0",
        "@typescript-eslint/eslint-plugin": "^8.0.0",
        "@typescript-eslint/parser": "^8.0.0",
        "esbuild": "0.27.4",
        "eslint": "^9.0.0",
        "globals": "^16.3.0",
        "tailwindcss": "^4.1.11",
        "typescript": "^5.0.0",
        "vite": "^8.0.0",
        "vitest": "^3.0.0"
    }
}